# Slack App 토큰 (api.slack.com에서 발급)
SLACK_BOT_TOKEN=xoxb-...         # OAuth Bot Token (Features > OAuth & Permissions)
SLACK_APP_TOKEN=xapp-...         # App-Level Token (Settings > Socket Mode)
SLACK_USER_ID=U...               # 브리핑 DM을 받을 본인 Slack Member ID (프로필 > Copy member ID)

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...     # https://console.anthropic.com/

# Obsidian Vault 경로 (절대 경로)
OBSIDIAN_VAULT=/path/to/your/Obsidian/Vault

# 브리핑 시각 (24시간 기준, 기본값 7 = 오전 7시)
BRIEFING_HOUR=7
